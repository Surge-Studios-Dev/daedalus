{
  "permissions": {
    "allow": [
      "Bash(flutter pub get:*)",
      "Bash(flutter analyze:*)",
      "Bash(flutter test:*)",
      "Bash(flutter run:*)",
      "Bash(flutter devices:*)",
      "Bash(dart format:*)",
      "Bash(dart analyze:*)",
      "Bash(dart run:*)",
      "Bash(dart test:*)",
      "Bash(npm test:*)",
      "Bash(npm run build:*)",
      "Bash(npm run corpus:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(xcrun simctl list:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/merge_bar.sh"
          }
        ]
      }
    ]
  }
}
