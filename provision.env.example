# Credentials for scripts/provision.sh - copy, fill, and place as:
#   $HOME/.surge/provision.env   studio-wide (set once, serves every app)
#   <app>/provision.env          per-app overrides (loaded second, wins)
#
# NEVER commit a filled copy. provision.sh adds provision.env to the app's
# .gitignore automatically; this .example (values empty) is the only variant
# that belongs in git.

# ---- Google Cloud / Firebase (studio-wide) --------------------------------
# `gcloud billing accounts list` -> XXXXXX-XXXXXX-XXXXXX. Needed for Functions.
GCP_BILLING_ACCOUNT=
# Firestore location for new databases (default nam5 = US multi-region).
FIRESTORE_LOCATION=nam5

# ---- Apple (studio-wide) ---------------------------------------------------
# Preferred: an App Store Connect API key (no 2FA prompts in automation).
# ASC_KEY_PATH points at fastlane's api_key JSON (key id, issuer id, .p8).
ASC_KEY_PATH=
# Fallback auth if no API key yet:
APPLE_ID=
APPLE_TEAM_ID=

# ---- Android (per-app) -----------------------------------------------------
# Password for the generated upload keystore (android/upload-keystore.jks).
ANDROID_KEYSTORE_PASS=
# Play service-account JSON for fastlane supply (studio-wide).
PLAY_JSON_KEY_PATH=

# ---- RevenueCat (studio-wide) ----------------------------------------------
# Secret API key (sk_...) from the RevenueCat dashboard -> API keys.
REVENUECAT_SECRET_KEY=
# Optional: reuse an existing RevenueCat project instead of creating one.
RC_PROJECT_ID=

# ---- PostHog (studio-wide) --------------------------------------------------
# Personal API key (phx_...) with project:write, for creating the per-app
# prod + dev project pair. The per-app project keys (phc_...) that the app
# builds use come from the created projects, via --dart-define, never here.
POSTHOG_PERSONAL_API_KEY=
# Organization id (default @current works for a single-org account).
POSTHOG_ORG_ID=
# API host (US cloud default; EU: https://eu.posthog.com).
POSTHOG_HOST=
