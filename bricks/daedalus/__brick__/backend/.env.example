# Functions runtime config. Copy to .env (gitignored) and fill what you use;
# unset keys make their feature a silent no-op, so emulator/CI runs work with
# an empty file. REMEMBER: the deploy machine's .env is state - record changes
# in the launch checklist or the next deploy silently reverts behavior.

# Discord ops notifications (notify/). One webhook per channel: Discord
# channel -> Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL.
# A GET on the URL does NOT return the channel name - confirm the mapping by
# posting a labeled test embed to each.
DISCORD_WEBHOOK_INSTALLS=
DISCORD_WEBHOOK_PURCHASES=
DISCORD_WEBHOOK_SUPPORT=

# Shared secret the RevenueCat dashboard sends verbatim as the Authorization
# header (openssl rand -hex 32). The endpoint fails closed while this is
# unset. Emulator gotcha: .env values injected into the runtime BEAT
# shell-exported vars - edit the file, don't export over it.
REVENUECAT_WEBHOOK_AUTH=

# Crashlytics -> PostHog bridge (index.ts onFatalIssue).
POSTHOG_PROJECT_KEY=
# POSTHOG_HOST=https://us.i.posthog.com

# Growth rail (SHARING.md): active share-link domain. The app's *.web.app
# host keeps working forever regardless - links minted on it never die.
# SHARE_LINK_BASE=https://go.example.app

# RevenueCat SECRET key (dashboard -> API keys) for promotional referral
# grants. Until set, reward days accrue as creditDays on referrals/{uid}
# and drain once the key lands (clients re-claim on boot).
REVENUECAT_SECRET=

# Storage bucket for share images; defaults to <project>.firebasestorage.app.
# STORAGE_BUCKET=
